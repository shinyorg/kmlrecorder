<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShinyKmlRecorder.ExportPage"
             Title="Export GPS Data">

    <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="FillAndExpand">
        
        <!-- Header Section -->
        <Label Text="Export GPS Data" FontSize="28" FontAttributes="Bold" HorizontalTextAlignment="Center" />
        
        <!-- Info Box -->
        <VerticalStackLayout Padding="15" Spacing="8" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}">
            <Label Text="GPS Points Available" FontAttributes="Bold" FontSize="16" />
            <Label Text="{Binding LogCount, StringFormat='{0} points'}" FontSize="18" TextColor="{StaticResource Primary}" />
            <Label Text="{Binding ExportStatus}" FontSize="12" TextColor="{StaticResource Gray500}" />
            <Label Text="{Binding ExportSummary}" FontSize="12" TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>

        <!-- Export Settings Button -->
        <Button 
            Text="Export Settings"
            Command="{Binding NavToSettingsCommand}"
            Padding="15,10"
            CornerRadius="8"
            BackgroundColor="{StaticResource PrimaryDark}"
            TextColor="White"
            FontAttributes="Bold" />
        
        <!-- Export Now Button -->
        <Button 
            Text="Export Now"
            Command="{Binding ExportNowCommand}"
            Padding="15,10"
            CornerRadius="8"
            BackgroundColor="{StaticResource Success}"
            TextColor="White"
            FontAttributes="Bold" />
        
        <!-- Export Folder Button -->
        <Button 
            Text="Open Export Folder"
            Command="{Binding OpenExportFolderCommand}"
            Padding="15,10"
            CornerRadius="8"
            BackgroundColor="{StaticResource Warning}"
            TextColor="White"
            FontAttributes="Bold"
            Margin="0,10,0,0" />

        <!-- Spacer -->
        <BoxView HeightRequest="0" VerticalOptions="FillAndExpand" />

        <!-- Status Indicator -->
        <ActivityIndicator IsRunning="{Binding IsExporting}" IsVisible="{Binding IsExporting}" 
                          Color="{StaticResource Primary}" Margin="0,0,0,10" />

    </VerticalStackLayout>

</ContentPage>

