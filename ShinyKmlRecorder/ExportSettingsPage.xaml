<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShinyKmlRecorder.ExportSettingsPage"
             Title="Export Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Export Settings"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="Choose the trip, export format, and delivery method. Settings persist across app restarts."
                   FontSize="12"
                   TextColor="{StaticResource Gray500}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10" />

            <!-- Trip Selection Section -->
            <VerticalStackLayout Padding="15" Spacing="10" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}">
                <Label Text="Trip Selection" FontAttributes="Bold" FontSize="16" />
                <Label Text="Choose a trip (WorkId) to export or select All Trips" 
                       FontSize="12" TextColor="{StaticResource Gray500}" />
                <Picker ItemsSource="{Binding Trips}"
                        SelectedItem="{Binding SelectedTrip}"
                        ItemDisplayBinding="{Binding Label}" />
            </VerticalStackLayout>

            <!-- Export Format Section -->
            <VerticalStackLayout Padding="15" Spacing="10" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}">
                <Label Text="Export Format" FontAttributes="Bold" FontSize="16" />
                <Picker ItemsSource="{Binding Formats}"
                        SelectedItem="{Binding SelectedFormat}" />
            </VerticalStackLayout>

            <!-- Delivery Method Section -->
            <VerticalStackLayout Padding="15" Spacing="10" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}">
                <Label Text="Delivery Method" FontAttributes="Bold" FontSize="16" />
                <Picker ItemsSource="{Binding Deliveries}"
                        SelectedItem="{Binding SelectedDelivery}" />
            </VerticalStackLayout>

            <!-- Azure Blob Settings -->
            <VerticalStackLayout Padding="15" Spacing="10" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}">
                <Label Text="Azure Blob Settings" FontAttributes="Bold" FontSize="16" />
                <Label Text="Used when Delivery Method = AzureBlob"
                       FontSize="12" TextColor="{StaticResource Gray500}" />
                <Entry Text="{Binding AzureAccountUrl}"
                       Placeholder="Account URL (https://account.blob.core.windows.net)" />
                <Entry Text="{Binding AzureContainerName}"
                       Placeholder="Container name" />
                <Entry Text="{Binding AzureSasToken}"
                       Placeholder="SAS token" />
            </VerticalStackLayout>

            <!-- Email Settings -->
            <VerticalStackLayout Padding="15" Spacing="10" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}">
                <Label Text="Email Settings" FontAttributes="Bold" FontSize="16" />
                <Label Text="Used when Delivery Method = Email"
                       FontSize="12" TextColor="{StaticResource Gray500}" />
                <Entry Text="{Binding EmailTo}"
                       Placeholder="To (email address)" />
                <Entry Text="{Binding EmailSubject}"
                       Placeholder="Subject" />
                <Editor Text="{Binding EmailBody}"
                        AutoSize="TextChanges"
                        Placeholder="Body" />
            </VerticalStackLayout>

            <!-- Info Section -->
            <VerticalStackLayout Padding="15" Spacing="8" BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource PrimaryDark}}">
                <Label Text="How settings work" FontAttributes="Bold" FontSize="14" />
                <Label Text="- Trip selection filters by WorkId" FontSize="12" />
                <Label Text="- Format controls KML vs GeoJSON" FontSize="12" />
                <Label Text="- Delivery sends to Azure, Email, or Share" FontSize="12" />
                <Label Text="- All settings are saved automatically" FontSize="12" />
            </VerticalStackLayout>

            <!-- Action Buttons -->
            <Button Text="Reset Settings"
                    Command="{Binding ResetFiltersCommand}"
                    Padding="15,10"
                    CornerRadius="8"
                    BackgroundColor="{StaticResource Danger}"
                    TextColor="White"
                    FontAttributes="Bold"
                    Margin="0,10,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
